// ── Routing ───────────────────────────────────────────────────────────────────

function doGet(e) {
    const action = (e.parameter.action || '').trim();
    try {
        if (action === 'init') {
            setupSchema();
            rebuildTeacherViewFromScratch();
            PropertiesService.getScriptProperties().setProperty('SCHEMA_VERSION', SCHEMA_VERSION);
            return json({ ok: true, schema: listSheets() });
        }
        ensureSchemaOnce();
        switch (action) {
            case 'health': return json({ ok: true, timestamp: new Date().toISOString() });
            case 'teachers': return json({ teachers: getTeachers() });
            case 'signupOptions': return json({ options: getSignupOptions() });
            case 'getAppointments': return json({ appointments: getAvailableAppointments() });
            case 'getConsultants': return json({ consultants: getConsultantNames() });
            case 'getConsultantStats': return json(getConsultantStats(e.parameter.consultant_id, e.parameter.name));
            case 'getConsultantHistory': return json({ rows: getConsultantHistory(e.parameter.consultant_id, e.parameter.name) });
            case 'getHoursLog': return json({ rows: getHoursLog(e.parameter.consultant_id, e.parameter.name) });
            case 'noShowOptions': return json({ options: getNoShowOptions() });
            case 'dashboardData': return json(getDashboardData(e.parameter.consultant_id, e.parameter.name));
            case 'checkPassword': return json(checkConsultantLogin(e.parameter.username, e.parameter.password));
            default: return json({ error: 'Unknown action.' }, 400);
        }
    } catch (err) {
        return json({ error: String(err.message || err) }, 500);
    }
}

function doPost(e) {
    try {
        ensureSchemaOnce();
        const body = JSON.parse(e.postData.contents || '{}');
        const action = (body.action || '').trim();
        const payload = body.payload || {};

        switch (action) {
            case 'submitSignup': return json(submitSignup(payload));
            case 'submitConsultation': return json(submitConsultation(payload));
            case 'submitHoursLog': return json(submitHoursLog(payload));
            case 'markNoShow': return json(markNoShow(payload));
            case 'revertNoShow': return json(revertNoShow(payload));
            default: return json({ error: 'Unknown action.' }, 400);
        }
    } catch (err) {
        return json({ error: String(err.message || err) }, 500);
    }
}

// ── Schema setup (runs once per deploy, not every request) ────────────────────

let _schemaReady = false;

function ensureSchemaOnce() {
    if (_schemaReady) return;
    const props = PropertiesService.getScriptProperties();
    if (props.getProperty('SCHEMA_VERSION') === SCHEMA_VERSION) {
        _schemaReady = true;
        return;
    }
    setupSchema();
    props.setProperty('SCHEMA_VERSION', SCHEMA_VERSION);
    _schemaReady = true;
}

function setupSchema() {
    const ss = getSpreadsheet();

    ensureSheet(ss, SHEETS.TEACHERS, [
        'user_id', 'name', 'email', 'department', 'active'
