// ── No-show ───────────────────────────────────────────────────────────────────

function markNoShow(payload) {
    requireFields(payload, ['consult_id']);

    const sheet = getSheet(SHEETS.CONSULTATIONS);
    const table = sheet.getDataRange().getValues();
    const headers = table[0];
    const idx = headerIndexMap(headers);

    const rowNumber = findRowById(table, idx, 'consult_id', payload.consult_id);
    if (!rowNumber) throw new Error('Sign-up record not found: ' + payload.consult_id);

    sheet.getRange(rowNumber, idx['no_show']).setValue(NO_SHOW_YES);

    // Mirror onto StudentVisits row (matched by student_email + appointment_date).
    const studentEmail = String(table[rowNumber - 1][idx['student_email'] - 1] || '').toLowerCase();
    const apptDate = String(table[rowNumber - 1][idx['appointment_date'] - 1] || '');
    setStudentVisitNoShow(studentEmail, apptDate, NO_SHOW_YES);

    const status = String(table[rowNumber - 1][idx['status'] - 1] || '');
    colorOneConsultationRow(rowNumber, status, NO_SHOW_YES);

    return { ok: true };
}

function revertNoShow(payload) {
    requireFields(payload, ['consult_id']);

    const sheet = getSheet(SHEETS.CONSULTATIONS);
    const table = sheet.getDataRange().getValues();
    const headers = table[0];
    const idx = headerIndexMap(headers);

    const rowNumber = findRowById(table, idx, 'consult_id', payload.consult_id);
    if (!rowNumber) throw new Error('Sign-up record not found: ' + payload.consult_id);

    sheet.getRange(rowNumber, idx['no_show']).setValue('');

    const studentEmail = String(table[rowNumber - 1][idx['student_email'] - 1] || '').toLowerCase();
    const apptDate = String(table[rowNumber - 1][idx['appointment_date'] - 1] || '');
    setStudentVisitNoShow(studentEmail, apptDate, '');

    const status = String(table[rowNumber - 1][idx['status'] - 1] || '');
    colorOneConsultationRow(rowNumber, status, '');

    return { ok: true };
}

function getNoShowOptions() {
    return getRows(SHEETS.CONSULTATIONS)
        .filter(function (row) {
            return String(row.no_show || '').toLowerCase() === NO_SHOW_YES;
        })
        .map(function (row) {
            return {
                consult_id: row.consult_id,
                label: row.appointment_date + ' — ' + row.student_name
            };
        })
        .sort(function (a, b) { return a.label.localeCompare(b.label); });
}

// Find the StudentVisits row matching (email, appointment_date) and set its
// no_show column. Silent no-op if not found (e.g. legacy rows that pre-date
// the no_show column).
function setStudentVisitNoShow(studentEmail, appointmentDate, value) {
    if (!studentEmail || !appointmentDate) return;
    const sheet = getSheet(SHEETS.STUDENT_VISITS);
    const data = sheet.getDataRange().getValues();
    if (data.length <= 1) return;
    const idx = headerIndexMap(data[0]);
    const emailCol = idx['student_email'] - 1;
    const apptCol = idx['appointment'] - 1;
    const nsCol = idx['no_show'];
    if (!nsCol) return; // no_show column not yet added on this sheet
    for (let r = 1; r < data.length; r++) {
        if (String(data[r][emailCol] || '').toLowerCase() === studentEmail
            && String(data[r][apptCol] || '') === appointmentDate) {
            sheet.getRange(r + 1, nsCol).setValue(value);
            return;
        }
    }
}

// ── Row coloring ──────────────────────────────────────────────────────────────

// Color a SINGLE row in Consultations. Called from submitConsultation /
// markNoShow / revertNoShow — replaces the old full-sheet scan + N writes.
function colorOneConsultationRow(rowNumber, status, noShow) {
    const sheet = getSheet(SHEETS.CONSULTATIONS);
    const lastCol = sheet.getLastColumn();
    const color = pickRowColor(status, noShow);
    sheet.getRange(rowNumber, 1, 1, lastCol).setBackground(color);
}

function pickRowColor(status, noShow) {
    if (String(noShow || '').toLowerCase() === NO_SHOW_YES) return '#f4c7c3';   // red — no-show
    if (String(status || '').toLowerCase() === STATUS.COMPLETED) return '#b7e1cd'; // green — completed
    return null;
}

// Full-table version: one batched setBackgrounds call (1 round-trip vs. N).
// Reserved for ?action=init.
function colorConsultationRows() {
    const sheet = getSheet(SHEETS.CONSULTATIONS);
    const data = sheet.getDataRange().getValues();
    if (data.length <= 1) return;
    const idx = headerIndexMap(data[0]);
    const statusCol = idx['status'] - 1;
    const noShowCol = idx['no_show'] - 1;
    const idCol = idx['consult_id'] - 1;
    const lastCol = sheet.getLastColumn();

    const matrix = [];
    for (let r = 1; r < data.length; r++) {
        const rowId = String(data[r][idCol] || '').trim();
        if (!rowId) {
            matrix.push(new Array(lastCol).fill(null));
            continue;
        }
        const color = pickRowColor(data[r][statusCol], data[r][noShowCol]);
        matrix.push(new Array(lastCol).fill(color));
    }
    sheet.getRange(2, 1, matrix.length, lastCol).setBackgrounds(matrix);
}

// ── Hours log ─────────────────────────────────────────────────────────────────

function submitHoursLog(payload) {
    requireFields(payload, ['consultant', 'date', 'hours', 'description']);

    const hours = Number(payload.hours);
    if (isNaN(hours) || hours <= 0) throw new Error('Hours must be a positive number.');

    const logId = generateId('HL');
    appendRow(SHEETS.HOURS_LOG, [
        logId,
        payload.consultant,
        String(payload.date),
        hours,
        payload.description,
        new Date().toISOString()
    ]);
    recalcConsultantStatsFor(payload.consultant);
    return { ok: true, log_id: logId };
}

// ── Row classification helpers ────────────────────────────────────────────────

function isCompletedRow(row) {
    if (String(row.status || '').toLowerCase() === STATUS.COMPLETED) return true;
    return !!row.consultant;
}

function isScheduledRow(row) {
    if (String(row.status || '').toLowerCase() === STATUS.COMPLETED) return false;
    if (String(row.no_show || '').toLowerCase() === NO_SHOW_YES) return false;
    if (String(row.status || '').toLowerCase() === STATUS.SCHEDULED) return true;
    return !row.consultant && !!row.appointment_date && !!row.student_name;
}

function findRowById(values, idx, column, id) {
    const colIndex = idx[column] - 1;
    for (let r = 2; r <= values.length; r++) {
        if (String(values[r - 1][colIndex]) === String(id)) return r;
    }
    return null;
}

function headerIndexMap(headerRow) {
    const map = {};
    headerRow.forEach(function (name, i) { map[String(name).trim()] = i + 1; });
    return map;
}

// ── Spreadsheet helpers ───────────────────────────────────────────────────────

let _ss = null;
function getSpreadsheet() {
    if (!_ss) _ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    return _ss;
}

const _sheets = {};
function getSheet(name) {
    if (!_sheets[name]) {
        const sheet = getSpreadsheet().getSheetByName(name);
        if (!sheet) throw new Error('Missing sheet: ' + name);
        _sheets[name] = sheet;
    }
    return _sheets[name];
}

function ensureSheet(ss, name, headers) {
    let sheet = ss.getSheetByName(name);
    if (!sheet) { sheet = ss.insertSheet(name); sheet.appendRow(headers); return; }
    if (sheet.getLastRow() === 0) { sheet.appendRow(headers); return; }

    const cur = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
    if (cur.length < headers.length) sheet.insertColumnsAfter(cur.length, headers.length - cur.length);
    for (let i = 0; i < headers.length; i++) {
        if (String(cur[i] || '') !== String(headers[i])) sheet.getRange(1, i + 1).setValue(headers[i]);
    }
}

function appendRow(sheetName, row) { getSheet(sheetName).appendRow(row); }

function clearDataRows(sheetName) {
    const sheet = getSheet(sheetName);
    const last = sheet.getLastRow();
    if (last > 1) sheet.getRange(2, 1, last - 1, sheet.getLastColumn()).clearContent();
}

function getRows(sheetName) {
    const sheet = getSheet(sheetName);
    const values = sheet.getDataRange().getValues();
    if (values.length <= 1) return [];
    const headers = values[0].map(function (h) { return String(h).trim(); });
    return values.slice(1).map(function (row) {
        const obj = {};
        headers.forEach(function (h, i) { obj[h] = row[i]; });
        return obj;
    });
}

function listSheets() { return getSpreadsheet().getSheets().map(function (s) { return s.getName(); }); }

function requireFields(payload, fields) {
    fields.forEach(function (f) {
        if (payload[f] === null || payload[f] === undefined || payload[f] === '') {
            throw new Error('Missing required field: ' + f);
        }
    });
}

function generateId(prefix) { return prefix + '-' + Utilities.getUuid().slice(0, 8).toUpperCase(); }
function round2(n) { return Math.round(Number(n) * 100) / 100; }

function json(obj) {
    const out = ContentService.createTextOutput(JSON.stringify(obj));
    out.setMimeType(ContentService.MimeType.JSON);
    return out;
}
