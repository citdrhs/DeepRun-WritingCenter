        'due_date',
        'notes',
        'next_steps',
        'teacher_department',
        'status',
        'no_show',
        'created_at',
        'completed_at'
    ]);

    ensureSheet(ss, SHEETS.CONSULTANT_STATS, [
        'consultant', 'total_consults', 'total_minutes', 'total_hours'
    ]);

    ensureSheet(ss, SHEETS.STUDENT_VISITS, [
        'submitted_at', 'student_name', 'student_email', 'student_grade', 'appointment', 'no_show'
    ]);

    ensureSheet(ss, SHEETS.TEACHER_VIEW, [
