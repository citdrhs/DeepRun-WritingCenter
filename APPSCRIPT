    ]);
}

// ── Login ─────────────────────────────────────────────────────────────────────

function checkConsultantLogin(username, password) {
    const u = String(username || '').trim().toLowerCase();
    const p = String(password || '').trim();
    if (!u || !p) return { ok: false };

    const sheet = getSheet(SHEETS.CONSULTANTS);
    const rows = sheet.getDataRange().getValues();
    if (rows.length <= 1) return { ok: false };
    const idx = headerIndexMap(rows[0]);

    for (let i = 1; i < rows.length; i++) {
        const row = rows[i];
        const storedUser = String(row[idx['username'] - 1] || '').trim().toLowerCase();
        const storedPass = String(row[idx['password'] - 1] || '').trim();
        const active = String(row[idx['active'] - 1]).toLowerCase();
        if (active === 'false') continue;
        if (u === storedUser && p === storedPass) {
            return {
                ok: true,
                name: String(row[idx['name'] - 1] || '').trim(),
                consultant_id: String(row[idx['consultant_id'] - 1] || '').trim()
            };
        }
    }
    return { ok: false };
}

// ── Forward (CC list) ─────────────────────────────────────────────────────────

function getCcEmails() {
    const sheet = getSpreadsheet().getSheetByName(SHEETS.FORWARD);
    if (!sheet) return '';
    const rows = sheet.getDataRange().getValues();
    if (rows.length <= 1) return '';
    const idx = headerIndexMap(rows[0]);
    const emailCol = idx['email'] ? idx['email'] - 1 : 1; // fall back to col 2 if unlabeled
    return rows.slice(1)
        .map(function (row) { return String(row[emailCol] || '').trim(); })
        .filter(function (email) { return email !== ''; })
        .join(',');
}

