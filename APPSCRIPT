/*
 * Deep Run Writing Center — Apps Script backend
 *
 * Sheets (source of truth):
 *   Teachers          user_id, name, email, department, active
 *   Consultants       consultant_id, name, username, password, active   (login lives here now)
 *   Consultations     consult_id, student_name, student_email, student_grade,
 *                     appointment_date, teacher_email, course, assignment_type,
 *                     google_doc_link, dual_enroll, consultant, before_conf,
 *                     after_conf, duration, due_date, notes, next_steps,
 *                     teacher_department, status, no_show, created_at, completed_at
 *   ConsultantStats   consultant, total_consults, total_minutes, total_hours
 *   HoursLog          log_id, consultant, date, hours, description, submitted_at
 *   StudentVisits     submitted_at, student_name, student_email, student_grade,
 *                     appointment, no_show
 *   TeacherView       teacher_email, teacher_department, student_name, consult_date,
 *                     dual_enroll, total_visits
 *   Appointments      appointment_id, description, max_signups
 *   Forward           label, email   (CC list for outgoing feedback emails)
 *
 * If a sheet's structure ever changes, bump SCHEMA_VERSION and hit ?action=init once
 * to force ensureSheet() to run.
 */

